# Maintainer: ghostkellz <ckelley@ghostkellz.sh>
# GhostBrew - sched-ext BPF scheduler for AMD Zen5/X3D and Intel Hybrid

pkgname=scx-ghostbrew
pkgver=0.3.3
pkgrel=1
pkgdesc="sched-ext BPF scheduler for AMD Zen5/X3D (V-Cache aware) and Intel 12th-14th gen hybrid (P-core/E-core)"
arch=('x86_64')
url="https://github.com/ghostkellz/ghostbrew"
license=('MIT')
depends=(
  'libbpf'
  'bpf'
)
makedepends=(
  'rust'
  'cargo'
  'clang'
  'llvm'
  'git'
)
optdepends=(
  'linux-cachyos: Recommended kernel with sched-ext (6.12+)'
  'linux-cachyos-lto: LTO optimized kernel with sched-ext'
  'linux-ghost: Custom kernel with ghost-vcache support'
  'scx-scheds: Other sched-ext schedulers for comparison'
)
provides=('scx_ghostbrew')
conflicts=('scx_ghostbrew')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
# Placeholder: the real checksum is pinned at release time by CI
# (see .github/workflows/release.yml) so a `makepkg` build verifies the
# downloaded source tarball instead of trusting it blindly. To pin manually,
# run `updpkgsums` in this directory (needs pacman-contrib).
sha256sums=('SKIP')

# For git builds (development)
# source=("git+${url}.git")
# sha256sums=('SKIP')

build() {
  cd "ghostbrew-${pkgver}"

  export RUSTFLAGS="-C target-cpu=native"
  cargo build --release --bin ghostbrew --bin scx_ghostbrew --target x86_64-unknown-linux-gnu
}

check() {
  cd "ghostbrew-${pkgver}"
  cargo test --release --target x86_64-unknown-linux-gnu
}

package() {
  cd "ghostbrew-${pkgver}"

  local release_dir="target/x86_64-unknown-linux-gnu/release"

  # Binary
  install -Dm755 "${release_dir}/ghostbrew" "${pkgdir}/usr/bin/ghostbrew"
  install -Dm755 "${release_dir}/scx_ghostbrew" "${pkgdir}/usr/bin/scx_ghostbrew"

  # Systemd service
  install -Dm644 "scx-ghostbrew.service" "${pkgdir}/usr/lib/systemd/system/scx-ghostbrew.service"

  # Man page
  install -Dm644 "man/ghostbrew.1" "${pkgdir}/usr/share/man/man1/ghostbrew.1"
  install -Dm644 "man/scx_ghostbrew.1" "${pkgdir}/usr/share/man/man1/scx_ghostbrew.1"

  # Icon
  install -Dm644 "assets/icons/ghostbrew-icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/ghostbrew.png"

  # Documentation
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "CHANGELOG.md" "${pkgdir}/usr/share/doc/${pkgname}/CHANGELOG.md"
  install -Dm644 "CONTRIBUTING.md" "${pkgdir}/usr/share/doc/${pkgname}/CONTRIBUTING.md"
  install -Dm644 "SECURITY.md" "${pkgdir}/usr/share/doc/${pkgname}/SECURITY.md"
  install -Dm644 "docs/README.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/README.md"
  install -Dm644 "docs/architecture/overview.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/architecture/overview.md"
  install -Dm644 "docs/guides/tuning.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/guides/tuning.md"
  install -Dm644 "docs/benchmarks.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/benchmarks.md"
  install -Dm644 "docs/benchmarks/README.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/benchmarks/README.md"
  install -Dm644 "docs/benchmarks/9950x3d-dev-report.txt" "${pkgdir}/usr/share/doc/${pkgname}/docs/benchmarks/9950x3d-dev-report.txt"
  install -Dm644 "docs/benchmarks/9950x3d-dev-report.json" "${pkgdir}/usr/share/doc/${pkgname}/docs/benchmarks/9950x3d-dev-report.json"
  install -Dm644 "docs/guides/troubleshooting.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/guides/troubleshooting.md"
  install -Dm644 "docs/features/dl-server.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/features/dl-server.md"
  install -Dm644 "docs/features/support-bundle.md" "${pkgdir}/usr/share/doc/${pkgname}/docs/features/support-bundle.md"
  install -Dm755 "release/install-system.sh" "${pkgdir}/usr/share/doc/${pkgname}/release/install-system.sh"

  # Example config
  install -Dm644 "examples/config/ghostbrew.toml" "${pkgdir}/usr/share/doc/${pkgname}/examples/config/ghostbrew.toml"

  # Example profiles
  install -dm755 "${pkgdir}/usr/share/doc/${pkgname}/examples/profiles"
  install -Dm644 examples/profiles/*.toml -t "${pkgdir}/usr/share/doc/${pkgname}/examples/profiles/"

  # Create config directories
  install -dm755 "${pkgdir}/etc/ghostbrew/profiles"

  # Shell completions
  install -dm755 "${pkgdir}/usr/share/bash-completion/completions"
  install -dm755 "${pkgdir}/usr/share/zsh/site-functions"
  install -dm755 "${pkgdir}/usr/share/fish/vendor_completions.d"
  "./${release_dir}/ghostbrew" completions bash > "${pkgdir}/usr/share/bash-completion/completions/ghostbrew"
  "./${release_dir}/ghostbrew" completions zsh > "${pkgdir}/usr/share/zsh/site-functions/_ghostbrew"
  "./${release_dir}/ghostbrew" completions fish > "${pkgdir}/usr/share/fish/vendor_completions.d/ghostbrew.fish"
  "./${release_dir}/scx_ghostbrew" --completions bash > "${pkgdir}/usr/share/bash-completion/completions/scx_ghostbrew"
  "./${release_dir}/scx_ghostbrew" --completions zsh > "${pkgdir}/usr/share/zsh/site-functions/_scx_ghostbrew"
  "./${release_dir}/scx_ghostbrew" --completions fish > "${pkgdir}/usr/share/fish/vendor_completions.d/scx_ghostbrew.fish"

  # License
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
